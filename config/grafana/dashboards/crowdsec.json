      "id": 104,
      "title": "📋 Live Logs",
      "type": "row"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Live CrowdSec logs — decisions, alerts, bouncer check-ins. Filter: only lines containing 'ban', 'decision', or 'alert'.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 37 },
      "id": 40,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "{container=~\".*crowdsec.*\"} |~ \"(ban|decision|alert|bouncer)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "CrowdSec Live Logs (bans / decisions / alerts)",
      "type": "logs"
    },

    {
      "datasource": { "type": "loki", "uid": "loki" },
      "description": "Banned IPs extracted from CrowdSec decision logs using regexp parsing. Shows scenario and source IP.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 47 },
      "id": 41,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": ["sum"],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "editorMode": "code",
          "expr": "sum by (scenario, source_ip) (\n  count_over_time(\n    {container=~\".*crowdsec.*\"} |~ \"alert\"\n    | regexp `alert : (?P<scenario>\\S+) by ip (?P<source_ip>\\S+)`\n    | scenario != \"\"\n  [$__range])\n)",
          "legendFormat": "",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Total Bans by IP & Scenario",
      "transformations": [
        { "id": "labelsToFields", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "scenario": "Scenario",
              "source_ip": "Source IP",
              "Value": "Count"
            }
          }
        },
        {
          "id": "sortBy",
          "options": { "fields": [{ "displayName": "Count", "desc": true }] }
        }
      ],
      "type": "table"
    }
